{
  "name": "cbs-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Classroom Booking System — JS/TS workspace (web + shared packages). Go API lives at repo root as its own module.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=23.11.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "gen:api": "pnpm --filter @cbs/api-client run generate"
  },
  "devDependencies": {
    "@babel/traverse": "7.29.7",
    "turbo": "2.5.8",
    "typescript": "catalog:"
  }
}
