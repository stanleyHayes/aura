# ── AURA backend configuration (§19.1) ──
# Copy to .env for local development. NEVER commit real secrets.

APP_ENV=development
APP_INSTITUTION_TZ=Africa/Accra
HTTP_PORT=8080

# PostgreSQL 18 (primary read/write) and optional read replica.
DATABASE_URL=postgres://cbs:cbs@localhost:5432/cbs?sslmode=disable
DATABASE_REPLICA_URL=

# Redis / Valkey 8 (cache, rate limit, SSE pub/sub). Optional in dev.
REDIS_URL=redis://localhost:6379/0

# S3-compatible object storage (MinIO in dev).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=cbs-local
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Cloudinary image uploads for buildings and rooms. Browser clients never see
# these secrets; local files upload through the API.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=aura/catalogue

# Auth. JWT_SIGNING_KEY is base64-encoded raw key bytes (HS256 dev fallback) or PEM for EdDSA.
# Generate a real secret for any shared/non-dev use:  openssl rand -base64 48
# The app refuses to start in production with this placeholder or a too-short key.
JWT_SIGNING_KEY=replace-with-openssl-rand-base64-48-min-32-chars
JWT_KEY_ID=dev-key-1
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Argon2id (benchmark on prod; defaults ~ 64 MiB / 3 / 2).
ARGON2_MEMORY_KIB=65536
ARGON2_ITERATIONS=3
ARGON2_PARALLELISM=2

# MFA secret encryption (AES-GCM). 32 raw bytes, base64-encoded.
# Generate a real key:  openssl rand -base64 32
# The app refuses to start in production with this placeholder.
MFA_ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# Login lockout.
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_WINDOW=15m

# Mail (Mailpit in dev).
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=no-reply@ashesi.edu
MAIL_USERNAME=
MAIL_PASSWORD=

# CORS allow-list (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Rate limits (requests per window).
RATE_LIMIT_DEFAULT_PER_MIN=120
RATE_LIMIT_AUTH_PER_MIN=10

# Telemetry (optional in dev).
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
