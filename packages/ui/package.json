{
  "name": "@cbs/ui",
  "version": "0.1.0",
  "private": true,
  "description": "Shared design tokens + shadcn/ui components for CBS web (§10.2).",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./tokens.css": "./src/styles/tokens.css",
    "./lib/cn": "./src/lib/cn.ts",
    "./lib/datetime": "./src/lib/datetime.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo node_modules/.cache"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-slot": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-toast": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "date-fns": "catalog:",
    "lucide-react": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@cbs/config": "workspace:*",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
