{
  "name": "@cbs/schemas",
  "version": "0.1.0",
  "private": true,
  "description": "Shared zod v4 schemas mirroring the API contract (§8, §10.1). Used by web + mobile.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./enums": "./src/enums.ts",
    "./entities": "./src/entities.ts",
    "./api": "./src/api.ts",
    "./forms": "./src/forms.ts"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cbs/config": "workspace:*",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
