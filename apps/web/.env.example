# ── CBS web (apps/web) configuration (§19.1) ──
# Only NEXT_PUBLIC_* values reach the browser. Never put secrets here.

# Where the Go API lives. Next rewrites /api/v1/* to this origin (server-only).
API_ORIGIN=http://localhost:8080

# Institution timezone for all human-facing rendering (§8.1). Public, inlined.
NEXT_PUBLIC_APP_TZ=Africa/Accra

# Canonical site origin for SEO metadata, sitemap and robots (§12.1).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
