{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "APP_VARIANT": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://aura-api-e9oh.onrender.com/api/v1"
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "android": { "buildType": "apk" },
      "env": {
        "APP_VARIANT": "staging",
        "EXPO_PUBLIC_API_BASE_URL": "https://aura-api-e9oh.onrender.com/api/v1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "APP_VARIANT": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
