# React Native / Expo dependency trees routinely carry lagging peer ranges
# (here: react-native-css-interop@0.2.6 — a transitive dep of nativewind@4.2.6 —
# still declares a `tailwindcss@~3` peer even though NativeWind 4.2.6 supports
# Tailwind v4, which the spec mandates). Legacy peer resolution is the standard
# Expo install posture; native compatibility is governed by the Expo SDK, not by
# npm's strict peer solver.
legacy-peer-deps=true
