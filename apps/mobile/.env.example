# Mobile app environment (EXPO_PUBLIC_* are inlined into the JS bundle).
# Copy to `.env` for local development. Never commit real secrets.

# Base URL of the Go REST API (Section 8). Defaults to the local API.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1

# Sentry DSN (optional locally; injected via EAS secrets in CI). When unset,
# Sentry init is skipped (see src/lib/sentry.ts).
EXPO_PUBLIC_SENTRY_DSN=

# Build-time only (consumed by app.config.ts / EAS, not inlined into JS):
# APP_VARIANT=development        # development | staging | production
# EAS_PROJECT_ID=                # from `eas init`
# SENTRY_ORG=cbs
# SENTRY_PROJECT=mobile
# SENTRY_AUTH_TOKEN=             # EAS secret, used by the Sentry Expo plugin
